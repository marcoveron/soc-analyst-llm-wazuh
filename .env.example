# Copy to `.env` and fill in (or `export` these in your shell before running).
# Never commit the real .env — only this example is tracked.

# --- Wazuh Indexer (read path: fetching alerts) ---
WAZUH_USER=admin
WAZUH_PASS=

# --- Wazuh Manager/Server API (response path: blocking IPs, etc.) ---
WAZUH_API_USER=wazuh
WAZUH_API_PASS=
WAZUH_API_HOST=192.168.100.79
WAZUH_API_PORT=55000

# Active Response command names — must match the agent's ar.conf exactly
# (the numeric suffix is the AR <timeout>).
WAZUH_AR_COMMAND=firewall-drop120
WAZUH_AR_UNBLOCK_COMMAND=firewall-allow0
WAZUH_AR_ISOLATE_COMMAND=isolate-host0
WAZUH_AR_UNISOLATE_COMMAND=unisolate-host0
WAZUH_AR_KILL_COMMAND=kill-process0

# Safety: 1 = simulate responses (no real firewall change). Recommended while testing.
DRY_RUN=1

# --- Optional threat-intel enrichment (features degrade gracefully if unset) ---
ABUSEIPDB_KEY=
VT_API_KEY=

# --- Optional proactive monitor (monitor.py) ---
MONITOR_INTERVAL=30
MONITOR_MIN_LEVEL=7
MONITOR_AUTO_BLOCK=0
